// Shared runtime configuration for all build variants.
// Keep real values outside repository and override per environment if needed.

// Example: https://example.com/config.php
SERVER_URL =
// Example: 1234567890
STORE_ID =
// Example: 123456789012
FIREBASE_PROJECT_ID =
// Example: AbCdEfGhIjKlMnOpQrStUv
APPSFLYER_DEV_KEY =

// Example: YES for verbose diagnostics on dev builds
IS_DEBUG = NO
// Example: YES to force .game state
IS_GAME_ONLY = NO
// Example: YES to force web branch
IS_WEB_ONLY = NO
// Example: YES to simulate no network startup
IS_NO_NETWORK = NO
// Example: YES to force ask notifications screen
ASK_NOTIFICATIONS = NO
// Example: YES to keep loading state forever
IS_INFINITY_LOADING = NO
// Example: YES to force test startup branch
TEST_STATE_FORCE_OPEN = NO

// Pass values to generated Info.plist for AppConfiguration.
INFOPLIST_KEY_SERVER_URL = $(SERVER_URL)
INFOPLIST_KEY_STORE_ID = $(STORE_ID)
INFOPLIST_KEY_FIREBASE_PROJECT_ID = $(FIREBASE_PROJECT_ID)
INFOPLIST_KEY_APPSFLYER_DEV_KEY = $(APPSFLYER_DEV_KEY)
INFOPLIST_KEY_IS_DEBUG = "$(IS_DEBUG)"
INFOPLIST_KEY_ASK_NOTIFICATIONS = "$(ASK_NOTIFICATIONS)"
INFOPLIST_KEY_TEST_STATE_FORCE_OPEN = "$(TEST_STATE_FORCE_OPEN)"
// Alias for tools/docs that refer to "force debug mode" (same value as TEST_STATE_FORCE_OPEN).
INFOPLIST_KEY_FORCE_DEBUG_MODE = "$(TEST_STATE_FORCE_OPEN)"

// Required for App Tracking Transparency (ATT) system prompt.
INFOPLIST_KEY_NSUserTrackingUsageDescription = "This allows us to measure and improve your experience and app performance."

// Fonts provided by application (UIAppFonts). Add bundled .ttf/.otf file names here or in BaseProject-Info.plist UIAppFonts array.
// Example single font: INFOPLIST_KEY_UIAppFonts = PaytoneOne-Regular.ttf
// Empty: keep UIAppFonts as an empty array in BaseProject-Info.plist (merged into the app Info.plist).
